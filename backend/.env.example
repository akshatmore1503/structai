# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/structai?retryWrites=true&w=majority

# OpenAI
OPENAI_API_KEY=sk-...

# Auth — must match NEXTAUTH_SECRET in frontend/.env.local
NEXTAUTH_SECRET=your-secret-here-min-32-chars

# App
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
